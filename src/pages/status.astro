---
import BaseLayout from '../layouts/BaseLayout.astro';
import { status } from '../content/status';
---

<BaseLayout title={status.title} description={status.description}>
  <section class="page-hero status-hero">
    <div class="wrap status-head">
      <div>
        <p class="eyebrow">{status.eyebrow}</p>
        <h1>{status.heading}</h1>
        <p class="lead">{status.lead}</p>
      </div>
      <a class="button alt" href={status.url} target="_blank" rel="noopener noreferrer">{status.openLabel}</a>
    </div>
  </section>

  <section class="section status-section" aria-label="实时服务状态">
    <div class="wrap">
      <div class="status-frame" aria-busy="true">
        <p class="status-frame-loading" aria-live="polite">正在连接状态站…</p>
        <iframe title={status.frameTitle} src={status.url} loading="eager" referrerpolicy="no-referrer" scrolling="no"></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const statusFrame = document.querySelector<HTMLIFrameElement>('.status-frame iframe');
  const statusFrameContainer = statusFrame?.closest<HTMLElement>('.status-frame');

  statusFrame?.addEventListener('load', () => {
    statusFrameContainer?.classList.add('is-loaded');
    statusFrameContainer?.setAttribute('aria-busy', 'false');
  });

  window.addEventListener('merak:theme-change', (event) => {
    if (!statusFrame) return;
    const theme = (event as CustomEvent<string>).detail;
    const url = new URL(statusFrame.src);
    url.searchParams.set('_merakTheme', theme);
    statusFrameContainer?.classList.remove('is-loaded');
    statusFrameContainer?.setAttribute('aria-busy', 'true');
    statusFrame.src = url.toString();
  });
</script>

<style>
  .status-hero { padding-bottom:clamp(2.5rem,5vw,4rem); }
  .status-head { position:relative; z-index:1; display:flex; align-items:end; justify-content:space-between; gap:2rem; }
  .status-head .lead { margin-bottom:0; }
  .status-section { padding:2rem 0 0; }
  .status-frame { position:relative; display:grid; height:clamp(30rem,52vh,34rem); overflow:hidden; background:color-mix(in srgb,var(--canvas) 90%,var(--steel)); }
  .status-frame-loading { position:absolute; inset:0; display:grid; place-items:center; margin:0; background:color-mix(in srgb,var(--canvas) 90%,var(--steel)); color:var(--muted); font:.72rem var(--font-data); letter-spacing:.1em; }
  .status-frame iframe { position:relative; z-index:1; display:block; width:100%; height:100%; border:0; opacity:0; background:var(--surface); color-scheme:light; transition:opacity .18s ease; }
  .status-frame.is-loaded iframe { opacity:1; }
  .status-frame.is-loaded .status-frame-loading { visibility:hidden; }
  :global(html[data-theme="dark"]) .status-frame iframe { color-scheme:dark!important; }
  :global(.site-footer) { margin-top:2rem; }
  @media (max-width:760px) { .status-head { display:grid; align-items:start; } .status-head .button { width:max-content; } .status-frame { height:44rem; } }
</style>
