---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy } from '../content/site-copy';
const page = copy.blog;
---

<BaseLayout title={page.title}><section class="page-hero"><div class="wrap hero-grid" data-reveal><div><p class="eyebrow">{page.eyebrow}</p><h1>{page.heading.split('\n').map((line) => <>{line}<br /></>)}</h1><p class="lead">{page.lead}</p></div><div class="hero-data"><strong>{page.count}</strong> 已公开记录<br />{page.lastEntry}</div></div></section><section class="section"><div class="wrap"><div class="tags" aria-label="文章分类">{page.categories.map((category) => <button class="tag" type="button" aria-pressed={category === '全部' ? 'true' : 'false'}>{category}</button>)}</div><div class="hangar-grid" style="margin-top:2rem" data-reveal>{page.posts.map((post) => <article class="bay wide"><p class="data">{post.category} / {post.date}</p><h2>{post.title}</h2><p>{post.excerpt}</p><div class="tags">{post.tags.map((tag) => <span class="tag">#{tag}</span>)}</div><a class="route" href={post.slug}>阅读全文</a></article>)}<aside class="bay narrow"><p class="data">TOPIC INDEX</p><h3>{page.topicHeading}</h3><div class="tags">{page.topics.map((topic) => <span class="tag">{topic}</span>)}</div></aside></div><p class="notice" style="margin-top:2rem">{page.notice}</p></div></section></BaseLayout>
