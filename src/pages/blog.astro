---
// 博文页面 - 博客列表
import BaseLayout from '../layouts/BaseLayout.astro';

// 示例博客文章数据（实际使用时可从 content collections 加载）
const posts = [
  {
    title: "欢迎来到我的博客",
    excerpt: "这里不是日更博客，而是思考的存档点。记录技术、赛车、航空与生活的点滴。",
    date: "2026-03-11",
    category: "生活",
    tags: ["随笔", "开场白"],
    slug: "/blog/welcome"
  }
];

const categories = ["全部", "技术", "赛车", "航空", "生活", "璇迹"];
---

<BaseLayout title="博文 - Merak 的思考存档点">
  <section class="blog-header">
    <div class="container">
      <h1 class="page-title">📝 博文</h1>
      <p class="blog-intro">
        这里不是日更博客，而是思考的存档点。
      </p>
      <p class="blog-subtitle">
        内容可能包括：技术笔记、F1 赛事分析、航空科普、生活随笔。<br />
        更新频率：随缘，但每篇都值得读。
      </p>
    </div>
  </section>

  <section class="blog-content">
    <div class="container">
      <!-- 分类过滤 -->
      <div class="category-filter">
        {categories.map((cat) => (
          <button class={`category-btn ${cat === '全部' ? 'active' : ''}`}>
            {cat}
          </button>
        ))}
      </div>

      <!-- 标签云 -->
      <div class="tag-cloud">
        <span class="tag-label">热门标签：</span>
        <a href="#" class="tag">F1</a>
        <a href="#" class="tag">空气动力学</a>
        <a href="#" class="tag">A380</a>
        <a href="#" class="tag">Ubuntu</a>
        <a href="#" class="tag">Linux</a>
        <a href="#" class="tag">服务器</a>
        <a href="#" class="tag">杭州</a>
        <a href="#" class="tag">AI</a>
        <a href="#" class="tag">璇迹</a>
      </div>

      <!-- 文章列表 -->
      <div class="posts-list">
        {posts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <span class="post-category">{post.category}</span>
              <time datetime={post.date}>{post.date}</time>
            </div>
            <h2 class="post-title">
              <a href={post.slug}>{post.title}</a>
            </h2>
            <p class="post-excerpt">{post.excerpt}</p>
            <div class="post-tags">
              {post.tags.map((tag) => (
                <span class="post-tag">#{tag}</span>
              ))}
            </div>
            <a href={post.slug} class="read-more">阅读全文 →</a>
          </article>
        ))}
      </div>

      <!-- 占位提示 -->
      <div class="placeholder-notice">
        <p>🚧 更多文章正在撰写中...</p>
        <p class="notice-sub">
        Under Construction...
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: 4rem 2rem 3rem;
    text-align: center;
    background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    margin: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(200, 200, 200, 0.2);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .blog-intro {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .blog-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .blog-content {
    padding: 3rem 2rem;
  }

  /* 分类过滤 */
  .category-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .category-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    transition: all 0.2s ease;
  }

  .category-btn:hover,
  .category-btn.active {
    background-color: var(--color-primary);
    color: white;
  }

  /* 标签云 */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
    padding: 1.5rem;
    background-color: var(--color-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .tag-label {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .tag {
    padding: 0.375rem 0.75rem;
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    transition: all 0.2s ease;
  }

  .tag:hover {
    background-color: var(--color-primary);
    color: white;
  }

  /* 文章列表 */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-card {
    background-color: var(--color-card);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
  }

  .post-category {
    padding: 0.25rem 0.75rem;
    background-color: var(--color-primary);
    color: white;
    border-radius: 9999px;
    font-weight: 500;
  }

  .post-meta time {
    color: var(--color-text-secondary);
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-title a {
    color: var(--color-text);
  }

  .post-title a:hover {
    color: var(--color-primary);
  }

  .post-excerpt {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-tag {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-secondary);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
  }

  .read-more {
    display: inline-block;
    font-weight: 600;
    color: var(--color-primary);
    transition: color 0.2s ease;
  }

  .read-more:hover {
    color: var(--color-primary-hover);
  }

  /* 占位提示 */
  .placeholder-notice {
    margin-top: 3rem;
    padding: 2rem;
    text-align: center;
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--color-border);
  }

  .placeholder-notice p:first-child {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .notice-sub {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .blog-header {
      padding: 3rem 1rem 2rem;
    }

    .blog-content {
      padding: 2rem 1rem;
    }

    .post-card {
      padding: 1.5rem;
    }

    .post-title {
      font-size: 1.25rem;
    }

    .tag-cloud {
      justify-content: center;
    }
  }
</style>
