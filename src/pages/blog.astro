---
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = [{ title:'欢迎来到我的博客', excerpt:'这里会写技术、赛车、航空和生活。更新不一定勤，但会尽量写清楚。', date:'2026-03-11', category:'生活', tags:['随笔','开场白'], slug:'/blog/welcome' }];
const categories = ['全部','技术','赛车','航空','生活','璇迹'];
---
<BaseLayout title="航行日志 | Merak"><section class="page-hero"><div class="wrap hero-grid" data-reveal><div><p class="eyebrow">LOGBOOK / OPEN ARCHIVE</p><h1>把想说的<br />记下来。</h1><p class="lead">技术笔记、F1、航空和生活随笔。有空就写，不凑更新频率。</p></div><div class="hero-data"><strong>01</strong> 已公开记录<br />LAST ENTRY / 2026.03.11</div></div></section><section class="section"><div class="wrap"><div class="tags" aria-label="文章分类">{categories.map((cat) => <button class="tag" type="button" aria-pressed={cat === '全部' ? 'true' : 'false'}>{cat}</button>)}</div><div class="hangar-grid" style="margin-top:2rem" data-reveal>{posts.map((post) => <article class="bay wide"><p class="data">{post.category} / {post.date}</p><h2>{post.title}</h2><p>{post.excerpt}</p><div class="tags">{post.tags.map((tag) => <span class="tag">#{tag}</span>)}</div><a class="route" href={post.slug}>阅读全文</a></article>)}<aside class="bay narrow"><p class="data">TOPIC INDEX</p><h3>常写的话题</h3><div class="tags"><span class="tag">F1</span><span class="tag">空气动力学</span><span class="tag">A380</span><span class="tag">Ubuntu</span><span class="tag">Linux</span><span class="tag">服务器</span><span class="tag">杭州</span><span class="tag">AI</span></div></aside></div><p class="notice" style="margin-top:2rem">更多文章还在整理。有新内容会放在这里。</p></div></section></BaseLayout>
