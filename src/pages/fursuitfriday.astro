---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('fursuitfriday'))
  .sort((a, b) => new Date(b.data.time).getTime() - new Date(a.data.time).getTime());
const latest = posts[0];
const isVideo = (path: string) => path.endsWith('.mp4');
---

<BaseLayout title="毛五 | Merak" description="Merak 的 FursuitFriday 照片与记录。">
  <section class="page-hero fursuit-intro">
    <div class="wrap fursuit-intro-grid" data-reveal>
      <div class="intro-copy">
        <p class="eyebrow">FURSUITFRIDAY</p>
        <h1>毛五。</h1>
        <p class="lead">一些出毛的照片、合照和现场记录。</p>
        <p class="intro-note">从 2025 年 1 月开始，按时间倒序整理。</p>
      </div>
      <figure class="latest-frame">
        {isVideo(latest.data.image) ? <video controls preload="metadata" src={latest.data.image}></video> : <img src={latest.data.image} alt={latest.data.caption} loading="eager" />}
        <figcaption><span>{latest.data.time}</span><span>最新记录</span></figcaption>
      </figure>
    </div>
  </section>

  <section class="fursuit-archive" aria-labelledby="archive-title">
    <div class="wrap">
      <div class="archive-head">
        <h2 id="archive-title">照片档案</h2>
        <p>{posts.length} 条记录，保留照片原始比例。</p>
      </div>
      <div class="contact-sheet" data-reveal>
        {posts.map((post) => (
          <figure class="photo-entry">
            <div class="photo-media">
              {isVideo(post.data.image) ? <video controls preload="metadata" src={post.data.image}></video> : <img src={post.data.image} alt={post.data.caption} loading="lazy" decoding="async" />}
            </div>
            <figcaption>
              <time datetime={post.data.time.replace(' ', 'T')}>{post.data.time}</time>
              <p>{post.data.caption}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .fursuit-intro { padding:clamp(3.5rem,8vw,7rem) 0; }
  .fursuit-intro::before, .fursuit-intro::after { content:none; }
  .fursuit-intro-grid { display:grid; grid-template-columns:minmax(16rem,.72fr) minmax(0,1.28fr); align-items:end; gap:clamp(2rem,6vw,7rem); }
  .intro-copy { padding-bottom:clamp(.25rem,2vw,2rem); }
  .intro-copy h1 { margin:.45rem 0 1rem; font-size:clamp(4.4rem,10vw,8.5rem); letter-spacing:-.04em; line-height:.85; }
  .intro-note { margin:1.8rem 0 0; color:var(--muted); font:.75rem/1.5 var(--font-data); }
  .latest-frame { margin:0; padding:1px; background:var(--line); }
  .latest-frame :global(img), .latest-frame :global(video) { display:block; width:100%; max-height:min(52vw,41rem); background:var(--surface); object-fit:contain; }
  .latest-frame figcaption { display:flex; justify-content:space-between; gap:1rem; padding:.7rem .8rem; background:var(--surface); color:var(--muted); font:.72rem/1.4 var(--font-data); }
  .latest-frame figcaption span:last-child { color:var(--ink); }
  .fursuit-archive { padding:clamp(3.5rem,8vw,7rem) 0 clamp(5rem,10vw,9rem); border-top:1px solid var(--line); }
  .archive-head { display:flex; justify-content:space-between; gap:2rem; align-items:baseline; margin-bottom:2rem; }
  .archive-head h2 { margin:0; }
  .archive-head p { max-width:30ch; margin:0; color:var(--muted); }
  .contact-sheet { columns:3 18rem; column-gap:1px; background:var(--line); border:1px solid var(--line); }
  .photo-entry { break-inside:avoid; display:block; margin:0 0 1px; padding:0; background:var(--surface); }
  .photo-media { background:var(--canvas); }
  .photo-media :global(img), .photo-media :global(video) { display:block; width:100%; height:auto; }
  .photo-entry figcaption { padding:.8rem .9rem 1rem; }
  .photo-entry time { display:block; color:var(--signal); font:.7rem/1.4 var(--font-data); }
  .photo-entry figcaption p { margin:.4rem 0 0; color:var(--ink); font-size:.88rem; line-height:1.55; white-space:pre-line; }
  @media (max-width:760px) { .fursuit-intro-grid { grid-template-columns:1fr; gap:2rem; } .intro-copy { padding:0; } .intro-copy h1 { font-size:clamp(4rem,22vw,6rem); } .latest-frame :global(img), .latest-frame :global(video) { max-height:none; } .archive-head { display:block; } .archive-head h2 { margin-bottom:.7rem; } .contact-sheet { columns:1; } }
</style>
