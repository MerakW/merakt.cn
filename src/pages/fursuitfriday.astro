---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('fursuitfriday'))
  .sort((a, b) => new Date(b.data.time).getTime() - new Date(a.data.time).getTime());
const latest = posts[0];
const isVideo = (path: string) => path.endsWith('.mp4');
---

<BaseLayout title="毛五 | Merak" description="Merak 的 FursuitFriday 照片与记录。">
  <section class="page-hero fursuit-hero">
    <div class="wrap hero-grid" data-reveal>
      <div>
        <p class="eyebrow">FURSUITFRIDAY / PHOTO LOG</p>
        <h1>毛五，<br />出门见朋友。</h1>
        <p class="lead">一些毛装照片、合照和现场小事。更新不固定，拍到了就放上来。</p>
        <div class="hero-count"><strong>{posts.length}</strong><span>条记录<br />从 2025.01 开始</span></div>
      </div>
      <figure class="latest-shot">
        {isVideo(latest.data.image) ? <video controls preload="metadata" src={latest.data.image}></video> : <img src={latest.data.image} alt={latest.data.caption} loading="eager" />}
        <figcaption><span>最新一条</span>{latest.data.time}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>照片记录</h2>
        <p>按时间倒序排列。照片保留原始比例，不裁切。</p>
      </div>
      <div class="fursuit-grid" data-reveal>
        {posts.map((post, index) => (
          <article class:list={['fursuit-card', { 'is-featured': index === 0 || index === 6 }]}>
            <div class="fursuit-media">
              {isVideo(post.data.image) ? <video controls preload="metadata" src={post.data.image}></video> : <img src={post.data.image} alt={post.data.caption} loading={index < 4 ? 'eager' : 'lazy'} />}
            </div>
            <div class="fursuit-body">
              <p class="data">{post.data.time}</p>
              <p class="fursuit-caption">{post.data.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .fursuit-hero { padding-bottom:clamp(3rem,7vw,6rem); }
  .hero-count { display:flex; align-items:center; gap:.9rem; margin-top:1.8rem; color:var(--muted); font:.74rem/1.5 var(--font-data); }
  .hero-count strong { color:var(--signal); font:900 clamp(3.5rem,8vw,6rem)/.8 var(--font-data); letter-spacing:-.13em; }
  .latest-shot { position:relative; margin:0; overflow:hidden; border:1px solid var(--line); background:var(--surface); box-shadow:0 1.5rem 3rem rgb(20 32 42 / .12); }
  .latest-shot :global(img), .latest-shot :global(video) { display:block; width:100%; height:auto; }
  .latest-shot::after { content:""; position:absolute; inset:0; pointer-events:none; background:linear-gradient(180deg,transparent 55%,rgb(11 18 24 / .72)); }
  .latest-shot figcaption { position:absolute; z-index:1; right:1rem; bottom:.8rem; display:flex; gap:.75rem; color:#fff; font:.72rem var(--font-data); }
  .latest-shot figcaption span { color:rgb(255 255 255 / .72); }
  .fursuit-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1px; border:1px solid var(--line); background:var(--line); }
  .fursuit-card { min-width:0; background:var(--surface); }
  .fursuit-card.is-featured { grid-column:span 2; }
  .fursuit-media { background:var(--canvas); }
  .fursuit-media :global(img), .fursuit-media :global(video) { display:block; width:100%; height:auto; transition:transform .4s cubic-bezier(.16,1,.3,1); }
  .fursuit-card:hover .fursuit-media :global(img) { transform:scale(1.025); }
  .fursuit-body { padding:1rem; }
  .fursuit-body .data { margin-bottom:.5rem; }
  .fursuit-caption { margin:0; color:var(--ink); font-size:.92rem; line-height:1.6; white-space:pre-line; }
  @media (max-width:760px) { .fursuit-grid { grid-template-columns:1fr; } .fursuit-card.is-featured { grid-column:span 1; } }
  @media (prefers-reduced-motion:reduce) { .fursuit-media :global(img) { transition:none; } }
</style>
