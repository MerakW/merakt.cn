---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy } from '../content/site-copy';
const page = copy.airways;
---

<BaseLayout title={page.title}><section class="page-hero"><div class="wrap hero-grid" data-reveal><div><p class="eyebrow">{page.eyebrow}</p><h1>{page.heading.split('\n').map((line) => <>{line}<br /></>)}</h1><p class="lead">{page.lead}</p><div class="actions"><a class="button" href="#fleet">{page.fleetButton}</a><a class="button alt" href="#notice">{page.noticeButton}</a></div></div><div class="hero-data"><strong>{page.heroData[0]}</strong>{page.heroData[1]}<br />{page.heroData[2]}</div></div></section><section class="section" id="fleet"><div class="wrap"><div class="section-head"><h2>{page.philosophyHeading}</h2><p>{page.philosophyLead}</p></div><div class="hangar-grid" data-reveal>{page.philosophyCards.map(([label, heading, text], index) => <article class={`bay ${index === 0 ? 'wide' : index === 1 ? 'narrow' : 'third'}`}><p class="data">{label}</p><h3>{heading}</h3><p>{text}</p></article>)}</div></div></section><section class="section"><div class="wrap"><div class="section-head"><h2>{page.loyaltyHeading}</h2><p>{page.loyaltyLead}</p></div><div class="hangar-grid" data-reveal>{page.loyaltyCards.map(([label, heading, text], index) => <article class={`bay ${index < 3 ? 'third' : 'wide'}`}><p class="data">{label}</p><h3>{heading}</h3><p>{text}</p></article>)}<div class="bay narrow"><p class="data">{page.currencyLabel}</p><div class="flight-code">{page.currencyCode}</div><p>{page.currency}</p></div></div></div></section><section class="section"><div class="wrap"><div class="hangar-grid" data-reveal><article class="bay wide"><p class="data">{page.lounge[0]}</p><h2>{page.lounge[1]}</h2><p>{page.lounge[2]}</p><p class="tags">{page.loungeTags.map((tag) => <span class="tag">{tag}</span>)}</p></article><article class="bay narrow"><p class="data">{page.firstClass[0]}</p><h3>{page.firstClass[1]}</h3><p>{page.firstClass[2]}</p></article></div><div id="notice" class="notice" style="margin-top:2rem"><strong>{page.noticeButton}：</strong>{page.notice}</div></div></section></BaseLayout>
