---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy } from '../content/site-copy';
const page = copy.merak;
---

<BaseLayout title={page.title}><section class="page-hero"><div class="wrap hero-grid" data-reveal><div><p class="eyebrow">{page.eyebrow}</p><h1>{page.heading.split('\n').map((line) => <>{line}<br /></>)}</h1><p class="lead">{page.lead}</p><div class="tags">{page.tags.map((tag) => <span class="tag">{tag}</span>)}</div></div><div class="portrait-stage"><img class="avatar" src="/avatar.webp" width="768" height="768" alt="Merak 的头像" decoding="async" fetchpriority="high" /></div></div></section><section class="section"><div class="wrap"><div class="hangar-grid" data-reveal><article class="bay wide"><p class="data">ORIGIN</p><h2>{page.origin}</h2><p>{page.originText}</p><h3>{page.interestsHeading}</h3><ul>{page.interests.map(([name, text]) => <li><strong>{name}：</strong>{text}</li>)}</ul></article><aside class="bay narrow"><p class="data">BASIC DATA</p><h3>基本信息</h3>{page.basics.map(([label, value]) => <p>{label}<br /><strong>{value}</strong></p>)}</aside></div></div></section><section class="section"><div class="wrap"><div class="section-head"><h2>{page.findHeading}</h2><p>{page.findLead}</p></div><ul class="social-list" data-reveal>{page.socials.map(([mark, name, description, href]) => <li><a href={href} target="_blank" rel="noopener noreferrer"><span><strong>{mark}</strong>　{name}</span><small>{description} ↗</small></a></li>)}</ul></div></section></BaseLayout>

<style>
  .portrait-stage { position:relative; display:grid; min-height:clamp(21rem,33vw,28rem); place-items:center; isolation:isolate; }
  .portrait-stage::before { content:""; position:absolute; z-index:-1; width:min(27rem,108%); aspect-ratio:1; border:1px solid color-mix(in srgb,var(--steel) 55%,transparent); border-radius:50%; background:radial-gradient(circle at center,color-mix(in srgb,var(--surface) 72%,transparent) 0 35%,transparent 35.4%),linear-gradient(90deg,transparent 49.8%,color-mix(in srgb,var(--steel) 45%,transparent) 50% 50.2%,transparent 50.4%),linear-gradient(transparent 49.8%,color-mix(in srgb,var(--steel) 45%,transparent) 50% 50.2%,transparent 50.4%); }
  .portrait-stage::after { content:""; position:absolute; z-index:-1; width:min(31rem,120%); height:42%; border-top:1px solid color-mix(in srgb,var(--signal) 65%,transparent); border-bottom:1px solid color-mix(in srgb,var(--steel) 55%,transparent); border-radius:50%; transform:rotate(-19deg); }
  .portrait-stage .avatar { width:min(24rem,96%); height:auto; aspect-ratio:auto; margin:0; border:0; border-radius:0; object-fit:contain; clip-path:none; filter:drop-shadow(0 1.2rem 1.3rem rgb(20 32 42 / .14)); }
  @media (max-width:760px) { .portrait-stage { min-height:20rem; } .portrait-stage .avatar { width:min(21rem,88vw); } }
</style>
