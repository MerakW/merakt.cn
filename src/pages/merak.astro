---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy } from '../content/site-copy';
const page = copy.merak;
---

<BaseLayout title={page.title}><section class="page-hero"><div class="wrap hero-grid" data-reveal><div><p class="eyebrow">{page.eyebrow}</p><h1>{page.heading.split('\n').map((line) => <>{line}<br /></>)}</h1><p class="lead">{page.lead}</p><div class="tags">{page.tags.map((tag) => <span class="tag">{tag}</span>)}</div></div><img class="avatar" src="/avatar.jpg" alt="Merak 的头像" /></div></section><section class="section"><div class="wrap"><div class="hangar-grid" data-reveal><article class="bay wide"><p class="data">ORIGIN</p><h2>{page.origin}</h2><p>{page.originText}</p><h3>{page.interestsHeading}</h3><ul>{page.interests.map(([name, text]) => <li><strong>{name}：</strong>{text}</li>)}</ul></article><aside class="bay narrow"><p class="data">BASIC DATA</p><h3>基本信息</h3>{page.basics.map(([label, value]) => <p>{label}<br /><strong>{value}</strong></p>)}</aside></div></div></section><section class="section"><div class="wrap"><div class="section-head"><h2>{page.findHeading}</h2><p>{page.findLead}</p></div><ul class="social-list" data-reveal>{page.socials.map(([mark, name, description, href]) => <li><a href={href} target="_blank" rel="noopener noreferrer"><span><strong>{mark}</strong>　{name}</span><small>{description} ↗</small></a></li>)}</ul></div></section></BaseLayout>
